<section class="collection-banner">
  <div class="page-width">
    <p class="eyebrow">Collection</p>
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="rte">{{ collection.description }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection banner",
  "settings": []
}
{% endschema %}
